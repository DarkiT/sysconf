	}
}

func demonstrateFunctionValidator(cfg *sysconf.Config) {
	// 添加函数式验证器
	cfg.AddValidateFunc(func(config map[string]any) error {
		// 示例：验证产品价格不能高于员工数量（荒谬的业务规则，仅用于演示）
		productMap, ok1 := config["product"].(map[string]any)
		companyMap, ok2 := config["company"].(map[string]any)

		if ok1 && ok2 {
			price, _ := productMap["price"].(float64)
			employeeCount, _ := companyMap["employee_count"].(int)

			if price > float64(employeeCount) {
				return fmt.Errorf("产品价格 (%.2f) 不能高于员工数量 (%d) - 这是一个示例业务规则", price, employeeCount)
			}
		}

		return nil
	})

	log.Println("✅ 添加函数式验证器成功")

	// 测试函数式验证器
	if err := cfg.Set("product.price", 50.0); err != nil {
		log.Printf("❌ 设置价格失败: %v", err)
	} else {
		log.Println("✅ 设置价格成功: 50.0（低于员工数）")
	}

	// 注意：这里不测试无效情况，因为会触发全量验证
}

func demonstrateCompositeValidator(cfg *sysconf.Config) {
	// 创建一个包含多个验证器的复合验证器
	composite := validation.NewCompositeValidator(
		"业务配置综合验证器",
		createCompanyValidator(),
		createProductValidator(),
		createUserValidator(),
	)

	log.Printf("✅ 创建复合验证器成功，包含 %d 个子验证器\n", len(composite.GetValidators()))
	log.Printf("   复合验证器名称: %s", composite.GetName())

	// 在实际应用中，你可以这样使用：
	// cfg.AddValidator(composite)
}
